# Example environment file for backend
# Copy this to .env and update values for your environment

# Database Configuration
# SQLite (development): sqlite:///./test.db
# MySQL: mysql+aiomysql://user:password@localhost/database_name
# PostgreSQL: postgresql://user:password@localhost/database_name
DATABASE_URL=sqlite:///./test.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Secret key for JWT/security (change in production)
SECRET_KEY=your-secret-key-change-in-production

# Debug mode (False in production)
DEBUG=True

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
